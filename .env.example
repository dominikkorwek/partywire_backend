PORT=8081
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-your-neon-host.us-east-1.aws.neon.tech/neondb?sslmode=require&channelBinding=require
SPRING_DATASOURCE_USERNAME=your-neon-user
SPRING_DATASOURCE_PASSWORD=your-neon-password
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend-project.vercel.app
FRONTEND_URL=https://your-frontend-project.vercel.app
SESSION_COOKIE_SAME_SITE=none
SESSION_COOKIE_SECURE=true
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_SQL_INIT_MODE=always
